{
  "name": "flowdesk",
  "version": "1.0.0",
  "workspaces": [
    "app",
    "server"
  ],
  "scripts": {
    "build": "npm run build --workspace=app",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm run dev --workspace=server",
    "client": "npm run dev --workspace=app"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}